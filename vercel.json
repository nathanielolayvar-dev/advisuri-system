{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_backend"
    }
  },
  "rewrites": [
    {
      "source": "/_backend/(.*)",
      "destination": "/_backend/$1"
    },
    {
      "source": "/((?!_backend/).*)",
      "destination": "/index.html"
    }
  ]
}
